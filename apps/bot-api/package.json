{
  "name": "bot-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier -w \"src/**/*.ts\""
  },
  "dependencies": {
    "archiver": "workspace:*",
    "express": "^4.18.2",
    "indexer": "workspace:*",
    "storage-w3up": "workspace:*",
    "x-client": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.1"
  }
}
